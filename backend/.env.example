# Backend environment configuration
# Copy to .env and fill in values

# ── Application ──────────────────────────────────────
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── QH (Quant Hub) API ──────────────────────────────
QH_API_BASE_URL=https://api.quanthub.example.com
QH_OHLC_ENDPOINT=/api/ohlc/
QH_API_TOKEN=your_api_token_here
QH_TIMEOUT_SECONDS=30
